{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "[python]": {
    "files.encoding": "utf8"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "models/*.pth": true,
    "models/*.pkl": true,
    "models/*.json": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "models/": true
  },
  "files.associations": {
    "*.pth": "binary",
    "*.pkl": "binary"
  }
}
